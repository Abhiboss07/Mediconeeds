# ============================================================================
# Mediconeeds — Environment template  (Phase 4: Auth & Security)
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# ============================================================================

# --- Database (MongoDB) -----------------------------------------------------
# Local:  mongodb://127.0.0.1:27017/mediconeeds
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/mediconeeds?retryWrites=true&w=majority
MONGODB_URI=

# --- Auth.js (NextAuth v5) --------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Public base URL of the app (used for callbacks / email links)
AUTH_URL=http://localhost:3000

# --- Demo / rollout ---------------------------------------------------------
# While "true", protected routes stay browsable WITHOUT login so the approved
# client demo keeps working. Flip to "false" to enforce real authentication.
DEMO_MODE=true
# Role assumed when DEMO_MODE is on (guest|buyer|seller|admin|superadmin).
DEMO_ROLE=seller

# --- First admin bootstrap (used by scripts/create-admin.mjs) ---------------
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Transactional email (SMTP / Nodemailer) --------------------------------
# Works with Gmail, Zoho, Hostinger, Brevo, Amazon SES, or any SMTP host.
# When SMTP_HOST is blank, emails are logged to the server console (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mediconeeds <no-reply@mediconeeds.com>"
SMTP_SECURE=false          # true for port 465 (implicit TLS)

# --- SMS OTP (MSG91) --------------------------------------------------------
# When MSG91_AUTH_KEY is blank, SMS/OTP codes are logged to the console (dev).
MSG91_AUTH_KEY=
MSG91_SENDER_ID=MEDICO
MSG91_OTP_TEMPLATE_ID=

# --- Google OAuth -----------------------------------------------------------
# From Google Cloud console. Blank = the "Continue with Google" button is hidden.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OTP tuning -------------------------------------------------------------
OTP_TTL_SECONDS=300        # code validity window (5 min)
OTP_MAX_PER_HOUR=5         # requests per identifier per hour (rate limit)

# --- Payments (Razorpay) — wired in a later phase ---------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Shopify — wired in a later phase ---------------------------------------
# Storefront: myshopify domain, e.g. dr-awish.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Custom-app Admin API access token (shpat_…) — required for live API product sync.
SHOPIFY_ADMIN_TOKEN=
# OAuth app credentials (only needed for the OAuth authorization-code flow,
# not for Admin-API token access). Leave blank if using SHOPIFY_ADMIN_TOKEN.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# --- File storage (local now; S3-compatible later) --------------------------
STORAGE_DRIVER=local       # local | s3
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Email over HTTP (Brevo) — REQUIRED in production (Render blocks SMTP ports).
# Sign up brevo.com, verify your sender, create an API key.
BREVO_API_KEY=
BREVO_FROM="Mediconeeds <abhicps19@gmail.com>"
