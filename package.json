{
  "name": "mediconeeds-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run tw && next build",
    "start": "next start",
    "lint": "next lint",
    "tw": "tailwindcss -i ./app/tw.css -o ./app/generated.css --minify",
    "import:csv": "node scripts/import-shopify-csv.mjs && node scripts/apply-catalog.mjs",
    "apply:catalog": "node scripts/apply-catalog.mjs",
    "import:mongo": "node --env-file=.env.local scripts/import-shopify-mongo.mjs"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "bcryptjs": "^3.0.3",
    "mongoose": "^9.7.3",
    "next": "^15.5.20",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^9.0.3",
    "papaparse": "^5.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "swiper": "^14.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.20",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17"
  },
  "overrides": {
    "nodemailer": "^9.0.3"
  }
}
